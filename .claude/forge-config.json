{
  "$schema": "https://json.schemastore.org/forge-config.json",
  "version": "1.10",
  "execution": {
    "defaultProvider": "claude-subscription",
    "providers": {
      "claude-subscription": {
        "type": "claude",
        "auth": "subscription"
      },
      "codex-subscription": {
        "type": "codex",
        "auth": "subscription",
        "sandbox": "workspace-write",
        "reasoningEffort": "low",
        "models": {
          "trivial": "default",
          "standard": "default",
          "complex": "default",
          "epic": "default"
        }
      },
      "claude-ollama": {
        "type": "claude",
        "auth": "ollama",
        "models": {
          "trivial": "CHANGE-ME-to-an-installed-ollama-model",
          "standard": "CHANGE-ME-to-an-installed-ollama-model",
          "complex": "CHANGE-ME-to-an-installed-ollama-model",
          "epic": "CHANGE-ME-to-an-installed-ollama-model"
        }
      }
    }
  },
  "modelProfile": "max-200",
  "modelProfiles": {
    "description": "WS-040: Subscription-aware model allocation. Forge uses claude CLI which requires a Claude subscription.",
    "profiles": {
      "max-200": {
        "description": "Best quality \u2014 Opus for executives and epic tasks",
        "subscription": "Claude Max $200/month",
        "executive": "claude-opus-4-8",
        "trivial": "claude-haiku-4-5-20251001",
        "standard": "claude-sonnet-5",
        "complex": "claude-sonnet-5",
        "epic": "claude-opus-4-8"
      },
      "max-100": {
        "description": "Great quality \u2014 Sonnet-centric with Haiku for bulk",
        "subscription": "Claude Max $100/month",
        "executive": "claude-sonnet-5",
        "trivial": "claude-haiku-4-5-20251001",
        "standard": "claude-haiku-4-5-20251001",
        "complex": "claude-sonnet-5",
        "epic": "claude-sonnet-5"
      },
      "pro": {
        "description": "Good quality \u2014 same allocation as Max $100",
        "subscription": "Claude Pro $20/month",
        "executive": "claude-sonnet-5",
        "trivial": "claude-haiku-4-5-20251001",
        "standard": "claude-haiku-4-5-20251001",
        "complex": "claude-sonnet-5",
        "epic": "claude-sonnet-5"
      }
    }
  },
  "duplicateDetection": {
    "description": "P27 Semantic Duplicate Detection \u2014 prevents creating semantically similar tasks",
    "semanticCheckEnabled": true,
    "semanticCheckThreshold": 0.5,
    "semanticSimilarityThreshold": 0.8,
    "maxSemanticChecksPerMinute": 10,
    "tokenSimilarityThreshold": 0.7
  },
  "taskAdmission": {
    "description": "Phase 1 (autonomy): admission gate for self/auto-generated tasks. Rejects redundant/invalid/already-done work before it enters the queue. Human tasks always bypass. Set shadowMode=true to log would-reject without enforcing.",
    "enabled": true,
    "shadowMode": false,
    "checkDuplicateTitle": true,
    "checkTargetsExist": true,
    "checkNotAlreadyDone": true,
    "valueFloor": true
  },
  "roadmapScheduling": {
    "description": "P27 Plan-Driven Daemon \u2014 schedules tasks from ROADMAP.md to work queue",
    "enabled": true,
    "scanIntervalMinutes": 15,
    "autoScheduleWaves": true,
    "respectDependencies": true,
    "maxTasksPerScan": 10,
    "sourceMarker": "planning",
    "intakeFiles": [
      ".planning/ROADMAP-SCOUT.md"
    ]
  },
  "security": {
    "profile": "standard",
    "profiles": {
      "strict": {
        "description": "All hooks active as blocking checks \u2014 defense in depth",
        "philosophy": "Maximum protection, blocks on any security concern"
      },
      "standard": {
        "description": "Critical protections block, others warn \u2014 balanced",
        "philosophy": "Balanced protection for normal development"
      },
      "minimal": {
        "description": "Only catastrophic operations blocked \u2014 relies on /gate",
        "philosophy": "Trust + manual checkpoints for experienced users"
      }
    },
    "hooks": {
      "block_dangerous": {
        "strict": "block",
        "standard": "block",
        "minimal": "block_reduced"
      },
      "secrets_scanner": {
        "strict": "block",
        "standard": "block",
        "minimal": "warn"
      },
      "git_guardian": {
        "strict": "block",
        "standard": "block",
        "minimal": "warn"
      },
      "lint_on_edit": {
        "strict": "block",
        "standard": "warn",
        "minimal": "off"
      },
      "prompt_guard": {
        "strict": "block",
        "standard": "warn",
        "minimal": "off"
      },
      "validate_quality": {
        "strict": "block",
        "standard": "warn",
        "minimal": "off"
      },
      "dependency_check": {
        "strict": "warn",
        "standard": "warn",
        "minimal": "off"
      },
      "log_activity": {
        "strict": "on",
        "standard": "on",
        "minimal": "on"
      },
      "session_init": {
        "strict": "on",
        "standard": "on",
        "minimal": "on"
      },
      "notify": {
        "strict": "on",
        "standard": "on",
        "minimal": "on"
      }
    }
  },
  "autonomy": {
    "level": "full",
    "description": "Controls how autonomous the build pipeline is",
    "options": {
      "full": "Runs build\u2192verify\u2192gate\u2192complete without stopping (pauses only for security issues, failures, misalignment)",
      "standard": "Runs build\u2192verify automatically, pauses for gate approval",
      "supervised": "Pauses after each major step (build, verify, gate) for human approval"
    },
    "pausePoints": {
      "afterWaves": false,
      "afterVerify": false,
      "afterGate": false,
      "onSecurityFindings": true,
      "onMisalignment": true,
      "onFailure": true
    },
    "flowMode": {
      "enabled": true,
      "description": "P27 PR-Based Output \u2014 auto-pushes feature branches and creates draft PRs for plan-driven tasks",
      "autoPushFeatureBranches": true,
      "autoCreateDraftPR": true,
      "autoMergeAfterApproval": false,
      "requireTestsPass": true,
      "onTestFailure": "create_fix_task",
      "logAllOperations": true,
      "branchNamingPattern": "feat/{phase}-{slug}"
    },
    "continuousOperation": {
      "enabled": false,
      "description": "When enabled, organization polls work queue for tasks",
      "pollIntervalSeconds": 30,
      "discoveryLoopIntervalSeconds": 1800,
      "maxConcurrentTasks": 1,
      "idleTimeoutMinutes": 60,
      "workQueuePath": ".company/work_queue.json"
    },
    "selfHealing": {
      "enabled": true,
      "maxRetries": 3,
      "retryDelaySeconds": 60,
      "autoFixHints": true
    },
    "autoPR": {
      "enabled": true,
      "branchPrefix": "daemon",
      "createDraftPR": true,
      "requireTestsPass": true,
      "requireSecretsClean": true,
      "requireLintPass": true,
      "checkDependencies": true,
      "autoFixLint": true,
      "onTestFailure": "create_fix_task",
      "onSecretFound": "block",
      "onDependencyIssue": "warn_in_pr"
    },
    "autoMerge": {
      "enabled": true,
      "requireTestsPass": true,
      "requireLintPass": true,
      "requireApproval": true,
      "allowMergeToMain": false,
      "allowedAuthors": [
        "daemon",
        "forge-*"
      ],
      "blockedPaths": [
        "forge-config.json",
        ".claude/settings.json",
        "CLAUDE.md"
      ],
      "reviewPaths": [
        ".claude/hooks/company/*audit*",
        ".claude/hooks/company/*judge*",
        ".claude/hooks/company/*admission*",
        ".claude/hooks/company/*steering*",
        ".claude/hooks/company/goal_tracker.py",
        ".claude/hooks/company/board_governance.py",
        ".claude/hooks/company/pr_output_manager.py",
        ".claude/hooks/company/forge_daemon.py",
        ".claude/hooks/company/employee_activator.py",
        ".claude/hooks/company/operation_loop.py",
        ".claude/hooks/company/failure_recovery.py",
        ".claude/hooks/company/infra_failure.py",
        ".claude/hooks/company/auto_merge_paths.py",
        ".github/workflows/*.yml",
        ".github/workflows/*.yaml",
        ".claude/forge-config.json"
      ],
      "mergeMethod": "squash",
      "deleteAfterMerge": true,
      "minChecksPassing": 1,
      "labelOnReady": "auto-merge-ready"
    },
    "workflowExecution": {
      "enabled": true,
      "confidenceThreshold": 0.7,
      "onJudgeError": "fallback",
      "model": null,
      "timeoutSeconds": 240,
      "maxDiffChars": 60000
    }
  },
  "fullAutonomy": {
    "description": "P25 Full Autonomous Operation \u2014 goal-driven scheduling, budget governance, and learning loops",
    "enabled": true,
    "budgetGovernorEnabled": false,
    "goalScheduler": {
      "description": "Dynamic goal prioritization based on business value and urgency",
      "enabled": true,
      "reorderInterval": 300,
      "strategicWeights": {
        "description": "WS-054-002: Rebalanced for 50%+ product/revenue focus",
        "G1": 0.8,
        "G2": 1.3,
        "G3": 1.0,
        "G4": 1.3,
        "G5": 0.9,
        "G6": 1.0,
        "G7": 0.8,
        "G8": 0.7,
        "G9": 0.8,
        "G10": 1.4,
        "G11": 0.9
      },
      "categoryWeights": {
        "description": "Weight multipliers by goal category",
        "product": 1.4,
        "revenue": 1.3,
        "infrastructure": 0.7,
        "quality": 0.9,
        "autonomy": 0.8
      }
    },
    "budgetGovernor": {
      "description": "Resource usage monitoring with automatic throttling at thresholds (DISABLED for Claude Max subscription - flat-rate billing)",
      "enabled": false,
      "thresholds": {
        "cautious": 70,
        "minimal": 85,
        "paused": 95
      }
    },
    "learningLoop": {
      "description": "Continuous improvement from task outcomes and patterns",
      "enabled": true,
      "rollingWindowDays": 30,
      "minSamplesForInsights": 10
    },
    "adaptiveScheduler": {
      "description": "Dynamic poll intervals and parallel worker scaling based on workload",
      "enabled": true,
      "pollIntervals": {
        "AGGRESSIVE": 15,
        "NORMAL": 30,
        "CONSERVATIVE": 60,
        "IDLE": 300
      },
      "workerCounts": {
        "AGGRESSIVE": 5,
        "NORMAL": 5,
        "CONSERVATIVE": 3,
        "IDLE": 1
      },
      "maxParallelWorkers": 5
    },
    "sessionContinuity": {
      "description": "Snapshot-based session recovery for crash resilience",
      "enabled": true,
      "snapshotIntervalSeconds": 300,
      "maxSnapshots": 5
    },
    "approvalLearner": {
      "description": "Pattern-based automatic approval for trusted operation types",
      "enabled": true,
      "minSuccessRateForAuto": 0.95,
      "refreshIntervalHours": 168
    }
  },
  "daemon": {
    "enabled": false,
    "pidFile": ".company/daemon.pid",
    "heartbeatFile": ".company/daemon.heartbeat",
    "logFile": ".company/logs/daemon.log",
    "logLevel": "INFO",
    "pollIntervalSeconds": 30,
    "discoveryLoopIntervalSeconds": 1800,
    "maxTasksPerHour": 50,
    "idleTimeoutSeconds": 1800,
    "gracefulShutdownSeconds": 30,
    "restartOnCrash": true,
    "maxRestarts": 3,
    "restartDelaySeconds": 60
  },
  "gitAutoUpdate": {
    "description": "Auto-restart daemon when origin/main has new commits",
    "enabled": true,
    "checkIntervalMinutes": 5,
    "maxWorkerWaitCycles": 10
  },
  "employeeInitiative": {
    "description": "P26 Employee Initiative \u2014 gates cadence to avoid subscription burn during idle periods",
    "enabled": true,
    "intervalMinutes": 15,
    "maxPerCycle": 2,
    "idleBackoffThreshold": 3,
    "idleCadenceMinutes": 120
  },
  "executiveLoop": {
    "description": "P18 Adaptive Intervals \u2014 executive activation with learning-based interval adjustment",
    "enabled": true,
    "intervalHours": 4,
    "triggerOnEmptyQueue": true,
    "skipIfQueueAbove": 5,
    "executives": [
      "forge-ceo",
      "forge-cto"
    ],
    "maxWorkItemsPerSession": 5,
    "adaptiveIntervals": {
      "description": "Learning-based interval adjustment based on session outcomes",
      "enabled": false,
      "minInterval": 1,
      "maxInterval": 24,
      "autoApplyThreshold": 0.8,
      "minSessionsForLearning": 20
    }
  },
  "proactive": {
    "enabled": true,
    "description": "P13 Proactive Initiative Engine \u2014 system proposes work autonomously",
    "scanIntervalMinutes": 60,
    "autoApprove": {
      "testSprints": true,
      "minorDependencyUpdates": true,
      "documentationFixes": true,
      "majorDependencyUpdates": false,
      "employeeReassignment": false,
      "securityFixes": true
    },
    "thresholds": {
      "testCoverageMinimum": 0.5,
      "idleEmployeeHours": 24,
      "failedTaskRetries": 2
    },
    "limits": {
      "maxProposalsPerScan": 10,
      "maxAutoApprovePerHour": 5
    }
  },
  "crossProject": {
    "enabled": true,
    "description": "P14 Multi-Project Orchestration \u2014 cross-project task routing and employee sharing",
    "autoRouting": {
      "enabled": true,
      "description": "Automatic task routing to appropriate projects based on content analysis",
      "confidenceThreshold": 0.7,
      "requireApprovalFor": [
        "high_risk",
        "complex"
      ]
    },
    "employeeSharing": {
      "enabled": true,
      "description": "Allow employees to work across multiple projects",
      "maxProjectsPerEmployee": 3,
      "preferProjectSpecialists": true
    },
    "knowledgeTransfer": {
      "enabled": true,
      "description": "Share patterns and decisions across projects",
      "autoApplyPatterns": false,
      "shareDecisions": true
    },
    "security": {
      "description": "Security controls for cross-project operations",
      "enforceProjectBoundaries": true,
      "auditCrossProjectOps": true
    },
    "defaultTemplates": {
      "description": "Default project templates by language/framework",
      "python": "python-lib",
      "node": "node-api",
      "minimal": "minimal"
    }
  },
  "boardGovernance": {
    "enabled": true,
    "description": "P21 Board Governance \u2014 market-aware leadership with external advisors",
    "createDuringBootstrap": true,
    "board": {
      "maxSize": 7,
      "minimumQuorum": [
        "board-chair",
        "forge-ceo"
      ],
      "allowDynamicMembers": true
    },
    "requireBoardForHiring": {
      "executive": true,
      "teamLead": true,
      "employee": false
    },
    "requireBoardForInvestment": {
      "enabled": true,
      "budgetThresholdUsd": 1000,
      "reallocationPercentThreshold": 20
    },
    "domainExpertise": {
      "autoDetectFromTemplate": true,
      "requireExternalPerspective": true,
      "templates": {
        "saas_platform": {
          "chairExpertise": [
            "saas-gtm",
            "subscription-economics",
            "b2b-growth"
          ],
          "advisorExpertise": [
            "product-led-growth",
            "enterprise-sales",
            "churn-reduction"
          ]
        },
        "ecommerce": {
          "chairExpertise": [
            "retail-dynamics",
            "marketplace-economics",
            "customer-acquisition"
          ],
          "advisorExpertise": [
            "payments",
            "logistics",
            "conversion-optimization"
          ]
        },
        "mobile_app": {
          "chairExpertise": [
            "mobile-ux",
            "app-store-optimization",
            "mobile-growth"
          ],
          "advisorExpertise": [
            "user-retention",
            "monetization",
            "engagement"
          ]
        },
        "api_service": {
          "chairExpertise": [
            "developer-relations",
            "api-ecosystems",
            "developer-tools"
          ],
          "advisorExpertise": [
            "developer-experience",
            "sdk-design",
            "documentation"
          ]
        },
        "data_platform": {
          "chairExpertise": [
            "data-economics",
            "ml-operations",
            "analytics-strategy"
          ],
          "advisorExpertise": [
            "data-privacy",
            "data-governance",
            "compliance"
          ]
        },
        "content_platform": {
          "chairExpertise": [
            "content-strategy",
            "media-economics",
            "platform-growth"
          ],
          "advisorExpertise": [
            "creator-economy",
            "engagement-optimization",
            "moderation"
          ]
        },
        "agency": {
          "chairExpertise": [
            "client-services",
            "project-economics",
            "service-scaling"
          ],
          "advisorExpertise": [
            "utilization-optimization",
            "margin-management",
            "talent"
          ]
        },
        "minimal": {
          "chairExpertise": [
            "general-business",
            "startup-operations"
          ],
          "advisorExpertise": []
        }
      }
    },
    "expansionPlanning": {
      "requireBoardApproval": true,
      "budgetConscious": true,
      "types": [
        "new_market",
        "new_product",
        "team_growth",
        "capability"
      ]
    },
    "advisorTypes": [
      "industry-expert",
      "customer-advocate",
      "investor-rep",
      "domain-advisor"
    ]
  },
  "gate": {
    "autoApprove": {
      "enabled": true,
      "maxCritical": 0,
      "maxHigh": 0,
      "requireCleanScan": true
    },
    "alwaysRequireHuman": false,
    "skipForTrivial": true
  },
  "orchestrator": {
    "description": "P28 BMAD/GSD Central Orchestrator \u2014 unified routing brain",
    "enabled": true,
    "fallbackOnError": true,
    "complexityOverrides": {
      "securitySensitiveMinLevel": "complex",
      "architecturalMinLevel": "complex"
    },
    "pipelineCustomization": {
      "skipReviewForTrivial": false,
      "requireGateForStandard": false,
      "securityAuditForComplex": false
    },
    "employeeHinting": {
      "enabled": true,
      "useCapabilityMatching": true
    }
  },
  "verify": {
    "autoFix": {
      "lintErrors": true,
      "testFailures": false
    },
    "requireAllPassing": {
      "lint": true,
      "tests": true,
      "build": false
    }
  },
  "notifications": {
    "onPhaseComplete": true,
    "onPipelineComplete": true,
    "onSecurityIssue": true,
    "onBlockingFailure": true
  },
  "permissions": {
    "autoCreateDirectories": [
      "src/**",
      "api/**",
      "test/**",
      "tests/**",
      "lib/**",
      "packages/**",
      "patterns/**",
      "middleware/**"
    ],
    "protectedPaths": [
      ".env*",
      "secrets/**",
      "*.pem",
      "*.key"
    ]
  },
  "agentTeams": {
    "description": "P84 Agent Teams Role Projection \u2014 experimental multi-agent execution mode (ADR-004)",
    "enabled": true,
    "experimentalAcknowledged": true,
    "executionStrategy": "role-projection",
    "triggerConditions": {
      "epicTasks": true,
      "complexTasks": true,
      "stuckTasks": true,
      "stuckRetryThreshold": 2,
      "blockedTasks": true,
      "reviewTeams": false
    },
    "composition": {
      "maxTeammates": 3,
      "excludeExecutives": true,
      "ephemeralHiringSignalThreshold": 5
    },
    "credit": {
      "leadWeight": 1.0,
      "teammateWeight": 0.3
    },
    "budget": {
      "tokenMultiplier": 3.0,
      "maxBudgetPerTeam": 45.0
    },
    "security": {
      "requireHookVerification": true,
      "verifySecretsScanner": true,
      "verifyGitGuardian": true
    }
  },
  "employeeIdeation": {
    "description": "WS-054-001: Auto-approve high-value low-effort employee ideas",
    "autoConvertApproved": true,
    "autoApproveEnabled": true,
    "autoApproveMaxValue": 0.7,
    "managerApproveMaxValue": 0.85,
    "autoApproveMaxEffort": [
      "trivial",
      "standard"
    ],
    "autoApproveDailyCap": 5,
    "managerApprovalEnabled": true,
    "executiveApprovalEnabled": true
  },
  "branchProtection": {
    "description": "GitHub branch protection rules applied by bin/forge-protect-main",
    "enabled": true,
    "branch": "main",
    "checkIntervalMinutes": 60,
    "autoRestore": false,
    "expectedChecks": [
      "Lint",
      "Security",
      "Hooks Validate"
    ],
    "requireNoForcePush": true,
    "requireNoDeletion": true,
    "enforceAdmins": false,
    "strictStatusChecks": false,
    "requirePullRequestReviews": null
  },
  "humanProtected": {
    "description": "Files/directories the daemon must NEVER modify - reserved for human editing",
    "enabled": true,
    "paths": [
      "CLAUDE.md",
      "forge-config.json",
      ".claude/settings.json",
      "pyproject.toml",
      "uv.lock"
    ],
    "requireApprovalFor": [
      "docs/*",
      "README.md"
    ]
  }
}
