{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-opus-4-5-20251101",
  "alwaysThinkingEnabled": true,
  "statusLine": {
    "type": "command",
    "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && .claude/status_lines/context_status.sh"
  },

  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Task",
      "TaskOutput",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskStop",
      "KillShell",
      "WebFetch",
      "WebSearch",
      "mcp__ide__getDiagnostics",
      "mcp__ide__*",
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npm test *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git status *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(git show *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git init *)",
      "Bash(git init)",
      "Bash(git clone *)",
      "Bash(git remote *)",
      "Bash(git tag *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(ls -* *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(head -* *)",
      "Bash(tail *)",
      "Bash(tail -* *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(echo *)",
      "Bash(echo)",
      "Bash(mkdir *)",
      "Bash(mkdir -p *)",
      "Bash(mkdir -* *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(find *)",
      "Bash(tree *)",
      "Bash(tree)",
      "Bash(xargs *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(grep *)",
      "Bash(grep -* *)",
      "Bash(sed *)",
      "Bash(sed -* *)",
      "Bash(awk *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(uv run *)",
      "Bash(uv *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(pip)",
      "Bash(pip3 *)",
      "Bash(pip3)",
      "Bash(ruff *)",
      "Bash(chmod +x *)",
      "Bash(chmod 755 *)",
      "Bash(chmod 644 *)",
      "Bash(tsc *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(jest *)",
      "Bash(pytest *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(jq *)",
      "Bash(date *)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(env *)",
      "Bash(printenv *)",
      "Bash(gh *)",
      "Bash(gh)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(test *)",
      "Bash([ *)",
      "Bash([[ *)",
      "Bash(true)",
      "Bash(false)",
      "Bash(cd *)",
      "Bash(pushd *)",
      "Bash(popd *)",
      "Bash(source *)",
      "Bash(. *)",
      "Bash(export *)",
      "Bash(unset *)",
      "Bash(read *)",
      "Bash(printf *)",
      "Bash(tee *)",
      "Bash(diff *)",
      "Bash(comm *)",
      "Bash(cmp *)",
      "Bash(sha256sum *)",
      "Bash(md5sum *)",
      "Bash(openssl *)",
      "Bash(base64 *)",
      "Bash(tar *)",
      "Bash(zip *)",
      "Bash(unzip *)",
      "Bash(gzip *)",
      "Bash(gunzip *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(docker *)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && uv run .claude/hooks/block_dangerous.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && uv run .claude/hooks/lint_on_edit.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && uv run .claude/hooks/secrets_scanner.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && uv run .claude/hooks/git_guardian.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && uv run .claude/hooks/forge_license.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && uv run .claude/hooks/log_activity.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && uv run .claude/hooks/validate_quality.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && uv run .claude/hooks/dependency_check.py"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && uv run .claude/hooks/context_monitor.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && uv run .claude/hooks/prompt_guard.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && uv run .claude/hooks/stop_validator.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && uv run .claude/hooks/subagent_validator.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && uv run .claude/hooks/session_init.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && uv run .claude/hooks/pre_compact_backup.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && uv run .claude/hooks/notify.py"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && uv run .claude/hooks/permission_auto.py"
          }
