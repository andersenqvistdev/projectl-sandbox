#!/usr/bin/env python3
"""Verify that Forge safety hooks correctly block dangerous operations.

Usage:
  bin/forge-test-guardrails [--verbose] [--hook HOOK]

Options:
  --verbose, -v   Show detail for passing tests too
  --hook HOOK     Test only hooks whose filename contains HOOK
                  (e.g. block_dangerous, secrets_scanner, git_guardian)
  --help, -h      Show this message

Exit codes:
  0  All tests passed
  1  One or more hooks failed to block (or wrongly blocked a safe payload)

No real commands are executed. Synthetic PreToolUse JSON payloads are piped
directly to each hook process; the hook exits before any tool runs.
"""

import json
import subprocess
import sys
from pathlib import Path
from typing import NamedTuple

HOOKS_DIR = Path(__file__).parent.parent / ".claude" / "hooks"


class Case(NamedTuple):
    name: str     # display label
    hook: str     # hook filename (relative to HOOKS_DIR)
    payload: dict # JSON object piped to hook stdin
    blocked: bool # True  → expect non-zero exit (hook fires)
                  # False → expect exit 0   (hook allows)


def _cases() -> list[Case]:
    # Build sensitive strings at runtime so this source file never contains
    # a literal pattern that would trigger secrets_scanner on Write.
    _aws = "AKIA" + "IOSFODNN7" + "FXMRPL9"  # 4+9+7 = 20 chars, no placeholder words

    return [
        # ── block_dangerous ──────────────────────────────────────────────────
        Case(
            "block_dangerous / allow safe bash",
            "block_dangerous.py",
            {"tool_name": "Bash", "tool_input": {"command": "git status"}},
            blocked=False,
        ),
        Case(
            "block_dangerous / block rm -rf",
            "block_dangerous.py",
            {"tool_name": "Bash", "tool_input": {"command": "rm -rf /tmp/test"}},
            blocked=True,
        ),
        # ── secrets_scanner ──────────────────────────────────────────────────
        Case(
            "secrets_scanner / allow safe write",
            "secrets_scanner.py",
            {
                "tool_name": "Write",
                "tool_input": {"file_path": "app.py", "content": "x = 1\n"},
            },
            blocked=False,
        ),
        Case(
            "secrets_scanner / block aws key",
            "secrets_scanner.py",
            {
                "tool_name": "Write",
                "tool_input": {
                    "file_path": "config.py",
                    "content": 'aws_key = "' + _aws + '"\n',
                },
            },
            blocked=True,
        ),
        # ── git_guardian ─────────────────────────────────────────────────────
        Case(
            "git_guardian / allow push to feature branch",
            "git_guardian.py",
            {
                "tool_name": "Bash",
                "tool_input": {"command": "git push origin feature/my-branch"},
            },
            blocked=False,
        ),
        Case(
            "git_guardian / block push to main",
            "git_guardian.py",
            {
                "tool_name": "Bash",
                "tool_input": {"command": "git push origin main"},
            },
            blocked=True,
        ),
    ]


def _run_hook(hook: str, payload: dict) -> tuple[int, str, str]:
    path = HOOKS_DIR / hook
    if not path.exists():
        return -1, "", f"hook not found: {path}"
    result = subprocess.run(
        [sys.executable, str(path)],
        input=json.dumps(payload),
        capture_output=True,
        text=True,
    )
    return result.returncode, result.stdout, result.stderr


def main() -> int:
    args = sys.argv[1:]
    if "-h" in args or "--help" in args:
        print(__doc__)
        return 0

    verbose = "-v" in args or "--verbose" in args
    hook_filter: str | None = None
    if "--hook" in args:
        idx = args.index("--hook")
        if idx + 1 >= len(args):
            print("error: --hook requires an argument", file=sys.stderr)
            return 2
        hook_filter = args[idx + 1]

    use_color = sys.stdout.isatty()
    GREEN = "\033[32m" if use_color else ""
    RED   = "\033[31m" if use_color else ""
    RESET = "\033[0m"  if use_color else ""

    cases = _cases()
    if hook_filter:
        cases = [c for c in cases if hook_filter in c.hook]
        if not cases:
            print(f"error: no test cases match --hook {hook_filter!r}", file=sys.stderr)
            return 2

    passed = failed = 0
    for case in cases:
        rc, stdout, stderr = _run_hook(case.hook, case.payload)

        if rc == -1:
            ok = False
            detail = stderr.strip()
        elif case.blocked:
            ok = rc != 0
            detail = f"expected non-zero exit (blocked), got {rc}"
        else:
            ok = rc == 0
            detail = f"expected exit 0 (allowed), got {rc}"

        tag = f"{GREEN}PASS{RESET}" if ok else f"{RED}FAIL{RESET}"
        print(f"{tag}  {case.name}")

        if not ok or verbose:
            print(f"      {detail}")
            if stdout.strip():
                print(f"      stdout: {stdout.strip()}")
            if stderr.strip():
                print(f"      stderr: {stderr.strip()[:300]}")

        if ok:
            passed += 1
        else:
            failed += 1

    total = passed + failed
    print(f"\n{total} tests: {passed} passed, {failed} failed")
    return 1 if failed else 0


if __name__ == "__main__":
    sys.exit(main())
