#!/usr/bin/env python3
# /// script
# requires-python = ">=3.10"
# ///
"""
forge-sandbox — one-command practice company seeder for Forge Academy.

Usage:
    forge-sandbox <target-dir> [--product NAME] [--skip-install]

Runs install.sh single-project into <target-dir>, seeds org.json with 3
employees, creates a 5-goal vision.md, initialises a git repo with an initial
commit, and writes a realistic history dataset (deliverable_gate.jsonl,
merge_audit.jsonl, autonomy_audit.json, efficiency_data.json, metrics.json)
so /dashboard, /calibrate, /efficiency, and /economics render meaningfully
from day one instead of empty states.

Arguments:
    target-dir          Directory to create (must not exist, or be empty)
    --product NAME      Company/product name (default: AcmeAI)
    --skip-install      Skip install.sh (seed-only mode; for tests / CI)

Exit codes:
    0  Sandbox ready
    1  Error
"""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from datetime import datetime, timedelta, timezone
from pathlib import Path

FORGE_ROOT = Path(__file__).parent.parent

_TTY = sys.stdout.isatty() and not os.environ.get("NO_COLOR")
GREEN = "\033[0;32m" if _TTY else ""
YELLOW = "\033[1;33m" if _TTY else ""
BOLD = "\033[1m" if _TTY else ""
DIM = "\033[2m" if _TTY else ""
NC = "\033[0m" if _TTY else ""


# ── Directory scaffolding ──────────────────────────────────────────────────────


def _ensure_company_dirs(target: Path) -> None:
    """Create the runtime .company/ subtree that install.sh normally builds."""
    for subdir in (
        ".company/state",
        ".company/logs",
        ".company/employees",
        ".company/metrics",
        ".company/templates",
        ".company/schemas",
    ):
        (target / subdir).mkdir(parents=True, exist_ok=True)


# ── Seed data generators ───────────────────────────────────────────────────────


