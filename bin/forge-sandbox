            "department": "engineering",
            "status": "available",
            "role": "Principal Architect",
            "capabilities": ["architecture", "design-decisions", "roadmap", "patterns"],
            "efficiency": {
                "score": 0.87,
                "tasks_completed": 8,
                "tasks_failed": 1,
                "average_attempts": 1.1,
                "last_updated": now,
            },
        },
        {
            "id": "senior-python-developer",
            "name": "Senior Python Developer",
            "type": "persistent",
            "department": "engineering",
            "status": "available",
            "role": "Senior Python Developer",
            "capabilities": ["python", "testing", "bug-fixes", "features"],
