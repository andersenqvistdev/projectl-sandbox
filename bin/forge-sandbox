        "projects": [],
    }


def _sanitise_product(product: str) -> str:
    """Strip control characters and newlines from user-supplied product name."""
    import re

    cleaned = re.sub(r"[\x00-\x1f\x7f]", " ", product).strip()
    return cleaned[:80] if cleaned else "AcmeAI"


def _build_vision_md(product: str) -> str:
    safe = _sanitise_product(product)
    return f"""\
# {safe} — Company Vision

### Period: Q3 2026 [status: active]

| Goal | Description | Success Metric | Owner |
|------|-------------|----------------|-------|
| G1: Code Quality | Maintain high test coverage and zero critical bugs across all services | Test coverage ≥ 80%, zero P0 bugs for 30 days | senior-python-developer |
| G2: Feature Velocity | Ship meaningful features at a sustainable pace | 2+ features shipped per week (rolling 4-week average) | forge-architect |
| G3: Security Posture | Harden the application against OWASP Top 10 and pass all security scans | Zero critical OWASP findings, all hooks green | security-engineer |
| G4: Developer Experience | Make onboarding and contribution fast and predictable | New contributor productive in < 30 minutes | forge-architect |
| G5: Autonomous Operation | Increase tasks completed without human intervention | ≥ 80% tasks autonomous (calibrate verified) | senior-python-developer |
"""


# ── History tasks ──────────────────────────────────────────────────────────────

_TASK_SPECS: list[tuple[str, str, bool, float]] = [
    # (title, employee_id, addresses_task, confidence)
    ("Add input validation to API endpoints", "senior-python-developer", True, 0.91),
    ("Implement rate limiting for external APIs", "security-engineer", True, 0.88),
    ("Refactor authentication middleware", "forge-architect", True, 0.94),
    ("Write tests for queue processing logic", "senior-python-developer", True, 0.86),
    ("Add secrets scanning hook for CI pipeline", "security-engineer", True, 0.95),
    ("Optimise database query performance", "senior-python-developer", True, 0.83),
    ("Document API endpoints in OpenAPI format", "forge-architect", True, 0.79),
    (
        "Fix race condition in concurrent task processing",
        "senior-python-developer",
        True,
        0.92,
    ),
    ("Implement audit log for security events", "security-engineer", True, 0.89),
    ("Add retry logic with exponential backoff", "senior-python-developer", True, 0.85),
    (
        "Review and harden trust tier permission matrix",
        "security-engineer",
        False,
        0.61,
    ),
    ("Configure deployment pipeline for CI/CD", "forge-architect", True, 0.88),
]


def _task_id(dt: datetime, index: int) -> str:
    return f"task-{dt.strftime('%Y%m%d%H%M%S')}-sb{index:04d}a"


def _build_history(
    product: str,
) -> tuple[list[dict], list[dict], dict, list[dict]]:
    """Return (gate_entries, audit_entries, work_queue, completed_task_dicts)."""
    now = datetime.now(timezone.utc)
    slug = product.lower().replace(" ", "-")

    gate_entries: list[dict] = []
    audit_entries: list[dict] = []
    completed: list[dict] = []
    failed: list[dict] = []

    n = len(_TASK_SPECS)
    for i, (title, employee, addresses_task, confidence) in enumerate(_TASK_SPECS):
        # Spread tasks evenly over the past 30 days
        offset_days = 30 - int(i * 30 / n)
        task_dt = now - timedelta(days=offset_days, hours=i % 8, minutes=(i * 13) % 60)
        task_id = _task_id(task_dt, i + 1)
        ts = task_dt.isoformat()
        pr_number = i + 1
        sha = f"{i + 1:03d}abc{(i * 7 + 13) * 111:09d}"[:40]
        pr_url = f"https://github.com/org/{slug}/pull/{pr_number}"

        blocked = not addresses_task or confidence < 0.7
        verdict = "PASS" if not blocked else "BLOCK"
        ci_state = "pass" if verdict == "PASS" else "fail"

        gate_entries.append(
            {
                "timestamp": ts,
                "task_id": task_id,
                "addresses_task": addresses_task,
                "confidence": confidence,
                "reason": (
                    f"PR diff implements {title.lower()} as described in the task"
                    if addresses_task
                    else f"PR diff does not sufficiently address: {title}"
                ),
                "blocked": blocked,
                "needs_manual_review": False,
                "error": None,
                "cached": False,
                "sha": sha,
                "skipped_reason": None,
                "pr_url": pr_url,
            }
        )

        audit_entries.append(
            {
                "ts": ts,
                "task_id": task_id,
                "pr": pr_number,
                "deliverable_verdict": verdict,
                "ci_state": ci_state,
                "merge_lever": "full_trust" if verdict == "PASS" else None,
            }
        )

        task_record = {
            "id": task_id,
            "title": title,
            "description": f"Sandbox task: {title}",
            "status": "completed" if verdict == "PASS" else "failed",
            "priority": 3,
            "assignee": employee,
            "created_at": ts,
            "updated_at": ts,
            "completed_at": ts if verdict == "PASS" else None,
            "attempts": 1,
            "pr_url": pr_url if verdict == "PASS" else None,
            "retry_history": [],
        }
        (completed if verdict == "PASS" else failed).append(task_record)

    # Two pending tasks for the student to tackle
    pending: list[dict] = []
    for j, (title, employee) in enumerate(
        [
            ("Add health-check endpoint with liveness probe", "forge-architect"),
            ("Increase test coverage for core scheduler", "senior-python-developer"),
        ]
    ):
        pending_dt = now - timedelta(hours=2 - j)
        pending.append(
            {
                "id": _task_id(pending_dt, 100 + j),
                "title": title,
                "description": f"Sandbox starter task: {title}",
                "status": "pending",
                "priority": 3,
                "assignee": employee,
                "created_at": pending_dt.isoformat(),
                "updated_at": pending_dt.isoformat(),
                "completed_at": None,
                "attempts": 0,
                "pr_url": None,
                "retry_history": [],
            }
        )

    work_queue = {
        "pending": pending,
        "in_progress": [],
        "completed": completed,
        "failed": failed,
        "blocked": [],
        "archived": [],
    }

    return gate_entries, audit_entries, work_queue, completed


def _build_autonomy_audit(completed_tasks: list[dict]) -> dict:
    """Build a two-snapshot ring buffer showing growth over time."""
    now = datetime.now(timezone.utc)
    n_completed = len(completed_tasks)
    n_total = n_completed + 1  # +1 for the blocked task

    def _snapshot(ts: str, completed: int, total: int, sha_suffix: str) -> dict:
        rate = round(completed / total, 3) if total else 0.0
        return {
            "version": 1,
            "generated_at": ts,
            "build_sha": f"abc{sha_suffix}def",
            "local_proxy": {
                "distinct_completed_with_pr": completed,
                "distinct_tasks_queued": total,
                "autonomy_proxy_rate": rate,
            },
            "ground_truth": {
                "sampled": completed,
                "merged": completed,
                "tier1_phantom": 0,
                "tier2_judged": completed,
                "tier2_addresses_task": completed,
                "tier2_errored": 0,
                "confirmed_real": completed,
                "trust_score": round(0.7 + (completed / total) * 0.2, 3)
                if total
                else 0.7,
                "phantom_rate": 0.0,
                "verified_autonomy_rate": round(completed / total, 3) if total else 0.0,
                "window_days": 30,
                "cohort_start": (now - timedelta(days=30)).strftime("%Y-%m-%d"),
                "sampled_windowed": completed,
                "confirmed_real_windowed": completed,
                "trust_score_windowed": round(0.75 + (completed / total) * 0.2, 3)
                if total
                else 0.75,
                "verified_autonomy_rate_windowed": round(completed / total, 3)
                if total
                else 0.0,
            },
            "phantoms": [],
        }

    week_ago = (now - timedelta(days=7)).isoformat()
    snap1 = _snapshot(week_ago, max(1, n_completed // 2), max(2, n_total), "111")
    snap2 = _snapshot(now.isoformat(), n_completed, n_total, "222")
    return {"version": 1, "entries": [snap1, snap2]}


def _build_efficiency_data() -> dict:
    now = datetime.now(timezone.utc).isoformat()
    return {
        "task_executions": [],
        "executive_sessions": [],
        "task_patterns": [],
        "memory_patterns": [],
        "optimizations": [],
        "token_usage": {
            "daily": {},
            "totals": {
                "executive_tokens": 12000,
                "task_tokens": 84000,
                "total_tokens": 96000,
            },
        },
        "cost_tracking": {
            "daily": {},
            "by_task": {},
            "by_session": {},
            "by_employee": {},
            "totals": {
                "input_tokens": 72000,
                "output_tokens": 24000,
                "total_tokens": 96000,
                "task_cost_usd": 0.48,
                "session_cost_usd": 0.06,
                "total_cost_usd": 0.54,
            },
        },
        "metadata": {
            "created_at": now,
            "last_updated": now,
            "rolling_window_days": 30,
            "version": "1.2",
        },
    }


def _build_metrics_json() -> dict:
    now = datetime.now(timezone.utc).isoformat()
    return {
        "project_id": "_default",
        "task_completions": [],
        "escalation_records": [],
        "daily_snapshots": [],
        "velocity": {"daily": [], "weekly_average": 2.5},
        "metadata": {
            "created_at": now,
            "last_updated": now,
            "rolling_window_days": 7,
        },
    }


# ── .gitignore helpers ─────────────────────────────────────────────────────────

_F4_GITIGNORE_BLOCK = """\
# Forge — runtime state (daemon-written; never commit)
.company/state/
.company/logs/
.company/runtime/
.company/results/
.company/agents/
.company/escalations/
.company/signals/
.company/ipc/
.company/workers/
.company/plans/
.company/metrics/
.company/reports/
.company/archive/
.company/knowledge/
.company/org.json
.company/approval_history.json
.company/context_monitor.json
.company/session_state.json
.company/external_rate_limits.json
.company/external_audit.log
.company/webhook_config.json
.company/budget_webhook_rate_limits.json
.company/compliance-report.json
.company/dashboard.port
.company/adaptive_scheduler_state.json
.company/daemon.pid
.company/daemon.heartbeat
.claude/settings.local.json
CLAUDE.local.md
.planning/STATE.md
.planning/COMPANY_STATE.md
"""

_BASE_GITIGNORE = """\
# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.env

# Logs
logs/
*.log

# Testing
.coverage
coverage.xml
.pytest_cache/
htmlcov/

"""


def _ensure_gitignore(target: Path) -> None:
    """Create or append the F4 daemon-written paths block to .gitignore."""
    gi = target / ".gitignore"
    existing = gi.read_text(encoding="utf-8") if gi.exists() else ""
    if ".company/org.json" in existing:
        return  # F4 block already present
    with gi.open("a", encoding="utf-8") as f:
        if existing and not existing.endswith("\n"):
            f.write("\n")
        f.write(_F4_GITIGNORE_BLOCK)


def _create_minimal_gitignore(target: Path) -> None:
    """Write a full .gitignore when --skip-install omits install.sh."""
    gi = target / ".gitignore"
    if gi.exists():
        _ensure_gitignore(target)
        return
    gi.write_text(_BASE_GITIGNORE + _F4_GITIGNORE_BLOCK, encoding="utf-8")


# ── Git helpers ────────────────────────────────────────────────────────────────


def _git_init(target: Path) -> None:
    """Initialise a git repo with an initial commit on branch main."""
    env = {
        **os.environ,
        "GIT_AUTHOR_NAME": "Forge Sandbox",
        "GIT_AUTHOR_EMAIL": "sandbox@forgeframework.dev",
        "GIT_COMMITTER_NAME": "Forge Sandbox",
        "GIT_COMMITTER_EMAIL": "sandbox@forgeframework.dev",
    }

    # git init — prefer -b main (git ≥2.28), fall back for older git
    try:
        subprocess.run(
            ["git", "init", "-b", "main", str(target)],
            check=True,
            capture_output=True,
            text=True,
        )
    except subprocess.CalledProcessError:
        subprocess.run(["git", "init", str(target)], check=True, capture_output=True)
        subprocess.run(
            ["git", "-C", str(target), "checkout", "-b", "main"],
            check=True,
            capture_output=True,
        )

    subprocess.run(
        ["git", "-C", str(target), "add", "."], check=True, capture_output=True, env=env
    )

    # Check if there's anything to commit (might be empty with --skip-install)
    status = subprocess.run(
        ["git", "-C", str(target), "status", "--porcelain"],
        capture_output=True,
        text=True,
    )
    if status.stdout.strip():
        subprocess.run(
            [
                "git",
                "-C",
                str(target),
                "commit",
                "-m",
                "chore: forge sandbox — initial commit",
            ],
            check=True,
            capture_output=True,
            env=env,
        )


# ── Main seed orchestration ────────────────────────────────────────────────────


def _run_install(target: Path) -> None:
    install_sh = FORGE_ROOT / "install.sh"
    # is_file() rejects missing paths and dangling symlinks; explicit symlink
    # rejection defends against a symlink-swap after the check.
    if not install_sh.is_file() or install_sh.is_symlink():
        print(f"  {YELLOW}⚠{NC}  install.sh not found at {install_sh}", file=sys.stderr)
        print(
            "       Run with --skip-install to seed without installing.",
            file=sys.stderr,
        )
        sys.exit(1)
    print(f"  {DIM}Running install.sh --type single-project …{NC}")
    result = subprocess.run(
        ["bash", str(install_sh), "--type", "single-project", str(target)],
        text=True,
    )
    if result.returncode != 0:
        print(
            f"\n  {YELLOW}⚠{NC}  install.sh exited with code {result.returncode}",
            file=sys.stderr,
        )
        sys.exit(1)


def seed(target: Path, product: str, skip_install: bool = False) -> None:
    """Create the sandbox in *target*, seeding all data files.

    This is the public API — tests call this directly instead of going via main().
    """
    if skip_install:
        _ensure_company_dirs(target)
        _create_minimal_gitignore(target)
    else:
        _run_install(target)
        _ensure_gitignore(target)  # append F4 block if install.sh didn't add it
        _ensure_company_dirs(target)  # ensure runtime dirs exist

    # --- org.json ---
    org_path = target / ".company" / "org.json"
    org_path.write_text(
        json.dumps(_build_org_json(product), indent=2), encoding="utf-8"
    )

    # --- vision.md ---
    vision_path = target / ".company" / "vision.md"
    vision_path.write_text(_build_vision_md(product), encoding="utf-8")

    # --- history ---
    gate_entries, audit_entries, work_queue, completed = _build_history(product)

    (target / ".company" / "state" / "deliverable_gate.jsonl").write_text(
        "\n".join(json.dumps(e) for e in gate_entries) + "\n", encoding="utf-8"
    )
    (target / ".company" / "state" / "merge_audit.jsonl").write_text(
        "\n".join(json.dumps(e) for e in audit_entries) + "\n", encoding="utf-8"
    )
    (target / ".company" / "state" / "work_queue.json").write_text(
        json.dumps(work_queue, indent=2), encoding="utf-8"
    )
    (target / ".company" / "state" / "autonomy_audit.json").write_text(
        json.dumps(_build_autonomy_audit(completed), indent=2), encoding="utf-8"
    )
    (target / ".company" / "state" / "efficiency_data.json").write_text(
        json.dumps(_build_efficiency_data(), indent=2), encoding="utf-8"
    )
    (target / ".company" / "metrics" / "metrics.json").write_text(
        json.dumps(_build_metrics_json(), indent=2), encoding="utf-8"
    )


def _print_next_steps(target: Path, product: str) -> None:
    print(f"""
{BOLD}Forge Sandbox ready!{NC}

  {GREEN}✓{NC}  Company: {product}
  {GREEN}✓{NC}  3 employees seeded (forge-architect, senior-python-developer, security-engineer)
  {GREEN}✓{NC}  5-goal vision created (.company/vision.md)
  {GREEN}✓{NC}  12-task history seeded (deliverable_gate.jsonl, merge_audit.jsonl)
  {GREEN}✓{NC}  2 pending tasks ready to work on
  {GREEN}✓{NC}  git repo initialised on main

{BOLD}Next steps:{NC}

  1. {DIM}cd{NC} {target}
  2. Run {BOLD}claude{NC} to open Claude Code in the sandbox
  3. Try {BOLD}/dashboard{NC}, {BOLD}/calibrate{NC}, {BOLD}/efficiency{NC}, {BOLD}/economics{NC}
  4. Pick up a pending task: run {BOLD}./bin/forge-queue{NC} to see the queue

{BOLD}GitHub Actions note:{NC}

  If you push this sandbox to GitHub, the initial Actions run will fail with a
  permissions error. Fix it once in repo Settings → Actions → General →
  Workflow permissions: enable {BOLD}Read and write permissions{NC} and tick
  {BOLD}Allow GitHub Actions to create and approve pull requests{NC}
  (equivalent to: {DIM}gh api repos/<org>/<repo> -X PATCH -F allow_auto_merge=true{NC}).

  This is the -F toggle referenced in the E-prime F4 brief.

{DIM}Tip: daemon-written files (.company/state/, .company/metrics/, .company/org.json)
are gitignored — git status stays clean even after the daemon runs.{NC}
""")


# ── CLI ────────────────────────────────────────────────────────────────────────


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description="Seed a practice Forge company for Forge Academy labs.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument(
        "target", help="Target directory (created if absent, must be empty if present)"
    )
    parser.add_argument(
        "--product", default="AcmeAI", help="Company/product name (default: AcmeAI)"
    )
    parser.add_argument(
        "--skip-install",
        action="store_true",
        help="Skip install.sh (seed-only; for tests)",
    )
    args = parser.parse_args(argv)

    target = Path(args.target).resolve()

    # Validate target
    if target.exists() and any(target.iterdir()):
        print(f"Error: target directory is not empty: {target}", file=sys.stderr)
        print("  Use an empty or non-existent directory.", file=sys.stderr)
        return 1

    target.mkdir(parents=True, exist_ok=True)

    print(f"\n{BOLD}Forge Sandbox Seeder{NC}")
    print(f"{DIM}Target: {target}{NC}")
    print(f"{DIM}Product: {args.product}{NC}\n")

    seed(target, args.product, skip_install=args.skip_install)
    _git_init(target)
    _print_next_steps(target, args.product)
    return 0


if __name__ == "__main__":
    sys.exit(main())
