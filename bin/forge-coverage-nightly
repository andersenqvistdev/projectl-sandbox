#!/usr/bin/env python3
"""
forge-coverage-nightly — Deterministic nightly coverage measurement.

Runs the full test suite with coverage once and writes a trusted
coverage.json at the project root, for the G1 goal assessor to read
(goal_tracker._read_trusted_coverage). This replaces letting an LLM
worker session attempt a full-suite pytest run as a queued task.

Run from the project root (or pass --company-dir / --project-root).
Typically invoked by the com.forgelabs.coverage LaunchAgent at 00:30 UTC.

Usage:
  bin/forge-coverage-nightly [--dry-run] [--company-dir DIR]
                             [--project-root DIR] [--timeout SECONDS]
                             [--verbose]

Options:
  --dry-run          Print what would happen; do not run pytest or write files
  --company-dir DIR  Override .company/ directory location
  --project-root DIR Project root to run pytest from
  --timeout SECONDS  Pytest subprocess timeout (default: 5400)
  --verbose          Print progress to stderr
  -h, --help         Show this message and exit

Exit codes:
  0  Success (summary printed, regardless of coverage percent)
  1  Fatal error (company dir not found, etc.)
  2  Usage error
"""

from __future__ import annotations

import sys
from pathlib import Path

_PROJECT_ROOT = Path(__file__).resolve().parent.parent
_HOOKS_COMPANY = _PROJECT_ROOT / ".claude" / "hooks" / "company"
sys.path.insert(0, str(_HOOKS_COMPANY))

import nightly_coverage as ncov  # noqa: E402

if __name__ == "__main__":
    sys.exit(ncov.main())
