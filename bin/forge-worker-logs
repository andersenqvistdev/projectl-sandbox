#!/usr/bin/env bash
# forge-worker-logs — Watch real-time worker output
#
# Usage:
#   forge-worker-logs              # List recent worker logs
#   forge-worker-logs watch        # Watch all active workers (live tail)
#   forge-worker-logs <task-id>    # Watch specific task
#   forge-worker-logs latest       # Watch most recent worker
#
# Workers stream output to: .company/logs/workers/worker-{task_id}.log

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
WORKER_LOG_DIR="${SCRIPT_DIR}/.company/logs/workers"

if [ ! -d "$WORKER_LOG_DIR" ]; then
    echo "No worker logs yet. Workers will create logs at:"
    echo "  $WORKER_LOG_DIR"
    exit 0
fi

case "${1:-}" in
    watch|w)
        echo "Watching all worker logs (Ctrl+C to stop)..."
        echo "---"
        # Watch all log files for changes
        tail -f "$WORKER_LOG_DIR"/*.log 2>/dev/null || echo "No active logs"
        ;;
    latest|l)
        LATEST=$(ls -t "$WORKER_LOG_DIR"/*.log 2>/dev/null | head -1)
        if [ -n "$LATEST" ]; then
            echo "Watching: $(basename "$LATEST")"
            echo "---"
            tail -f "$LATEST"
        else
            echo "No worker logs found"
        fi
        ;;
    help|--help|-h)
        echo "forge-worker-logs — Watch real-time worker output"
        echo ""
        echo "Usage:"
        echo "  forge-worker-logs              # List recent worker logs"
        echo "  forge-worker-logs watch        # Watch all active workers"
        echo "  forge-worker-logs <task-id>    # Watch specific task"
        echo "  forge-worker-logs latest       # Watch most recent worker"
        echo ""
        echo "Log location: .company/logs/workers/"
        ;;
    "")
        # List recent logs
        echo "Recent worker logs:"
        echo "---"
        # Collect first, then branch: with `set -o pipefail`, `ls | head` gets a
        # SIGPIPE when head closes early, "failing" the pipeline and firing a
        # `|| echo "(none)"` fallback AFTER real results were already printed
        # (bin-audit finding, 2026-07-17).
        recent_logs=$(ls -t "$WORKER_LOG_DIR"/*.log 2>/dev/null | head -10 || true)
        if [ -z "$recent_logs" ]; then
            echo "  (none)"
        else
            echo "$recent_logs" | while read -r file; do
                size=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null || echo "?")
                name=$(basename "$file")
                task_id=$(echo "$name" | sed 's/worker-//' | sed 's/\.log//')
                echo "  $task_id (${size}B)"
            done
        fi
        echo ""
        echo "Commands:"
        echo "  forge-worker-logs watch     # Live tail all logs"
        echo "  forge-worker-logs latest    # Watch most recent"
        ;;
    *)
        # Specific task ID
        TASK_LOG="$WORKER_LOG_DIR/worker-$1.log"
        if [ -f "$TASK_LOG" ]; then
            echo "Watching: $1"
            echo "---"
            tail -f "$TASK_LOG"
        else
            # Try partial match
            MATCH=$(ls "$WORKER_LOG_DIR"/worker-*"$1"*.log 2>/dev/null | head -1)
            if [ -n "$MATCH" ]; then
                echo "Watching: $(basename "$MATCH")"
                echo "---"
                tail -f "$MATCH"
            else
                echo "No log found for task: $1"
                echo "Available logs:"
                ls "$WORKER_LOG_DIR"/*.log 2>/dev/null | xargs -I{} basename {} | head -5
            fi
        fi
        ;;
esac
