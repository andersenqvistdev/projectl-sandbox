#!/usr/bin/env bash
# forge-model-profile — Switch the active Forge model profile
#
# Usage:
#   forge-model-profile              # Show current profile and all profiles
#   forge-model-profile <name>       # Switch to named profile (warns on worker mismatch)
#   forge-model-profile <name> --sync-workers  # Switch and sync maxParallelWorkers
#   forge-model-profile --list       # List all profiles
#   forge-model-profile --help       # Show this help
#
# The --sync-workers flag sets adaptiveScheduler.maxParallelWorkers to the
# profile's 'workers' field.  Without it, a mismatch is warned but not fixed.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SWITCHER="${SCRIPT_DIR}/.claude/hooks/company/model_profile_switcher.py"

if [ ! -f "$SWITCHER" ]; then
    echo "Error: model_profile_switcher.py not found at ${SWITCHER}" >&2
    exit 1
fi

case "${1:-}" in
    help|--help|-h)
        head -11 "$0" | tail -9
        exit 0
        ;;
esac

exec uv run "$SWITCHER" "$@"
