#!/usr/bin/env bash
# forge-status — Forge Labs daemon operational snapshot
#
# Usage:
#   forge-status          # Concise read-only status snapshot
#   forge-status --json   # Machine-readable JSON output
#   forge-status --help   # Show this help
#
# Exit codes:
#   0 — daemon running, circuit breaker CLOSED
#   1 — daemon not running or circuit breaker OPEN/HALF_OPEN
#   2 — usage error

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
MONITOR="${SCRIPT_DIR}/.claude/hooks/company/status_monitor.py"

if [ ! -f "$MONITOR" ]; then
    echo "Error: status_monitor.py not found at ${MONITOR}" >&2
    exit 1
fi

case "${1:-}" in
    help|--help|-h)
        head -11 "$0" | tail -8
        ;;
    version|--version|-v)
        CONFIG="${SCRIPT_DIR}/forge-config.json"
        if [ -f "$CONFIG" ]; then
            ver="$(python3 -c "import json,sys; d=json.load(open('$CONFIG')); print(d.get('version',''))" 2>/dev/null)"
        fi
        if [ -n "${ver:-}" ]; then
            echo "Forge ${ver}"
        else
            echo "Forge (unknown version)"
        fi
        ;;
    *)
        exec uv run "$MONITOR" "$@"
        ;;
esac
