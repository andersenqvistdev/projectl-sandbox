#!/usr/bin/env bash
# forge-doctor — first-run preflight checks for known Forge gotchas
#
# Usage:
#   forge-doctor          # Run all checks, print PASS/WARN/FAIL with remedies
#   forge-doctor --json   # Machine-readable JSON output
#   forge-doctor --help   # Show this help
#
# Exit codes:
#   0 — all checks passed (no FAILs)
#   1 — one or more checks FAILED

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
DOCTOR="${SCRIPT_DIR}/.claude/hooks/company/forge_doctor.py"

if [ ! -f "$DOCTOR" ]; then
    echo "Error: forge_doctor.py not found at ${DOCTOR}" >&2
    exit 1
fi

case "${1:-}" in
    help|--help|-h)
        head -10 "$0" | tail -7
        ;;
    deep)
        shift
        exec uv run "$DOCTOR" --deep "$@"
        ;;
    *)
        exec uv run "$DOCTOR" "$@"
        ;;
esac
