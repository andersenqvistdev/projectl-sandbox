#!/usr/bin/env python3
# /// script
# requires-python = ">=3.10"
# ///
"""
forge-validate — Fast post-install structural validation for Forge.

Checks the static file structure of an installed Forge project without running
any hooks or making network calls. Complements forge-doctor (which checks
runtime conditions like claude on PATH, gh auth, etc.) by focusing on whether
all expected files landed in the right places.

Usage:
    forge-validate [TARGET_DIR] [--json] [--strict]

    TARGET_DIR   Directory to validate (default: current directory)
    --json       Output results as JSON instead of human-readable text
    --strict     Exit 1 on WARNs as well as FAILs (default: only FAILs)

Exit codes:
    0  All required checks passed (WARNs allowed unless --strict)
    1  One or more checks FAILED (or WARNed with --strict)

Examples:
    forge-validate                  # Validate current directory
    forge-validate /path/to/project # Validate specific path
    forge-validate --json           # Machine-readable output (CI use)
    forge-validate --strict         # Treat warnings as failures
"""

from __future__ import annotations

import json
import os
import sys
from dataclasses import dataclass, field
from pathlib import Path
from typing import Literal

Status = Literal["PASS", "WARN", "FAIL", "SKIP"]

# ── Icons ─────────────────────────────────────────────────────────────────────
_NO_COLOR = not sys.stdout.isatty() or os.environ.get("NO_COLOR") or os.environ.get("FORGE_NO_COLOR")

GREEN = "" if _NO_COLOR else "\033[0;32m"
YELLOW = "" if _NO_COLOR else "\033[1;33m"
RED = "" if _NO_COLOR else "\033[0;31m"
CYAN = "" if _NO_COLOR else "\033[0;36m"
BOLD = "" if _NO_COLOR else "\033[1m"
DIM = "" if _NO_COLOR else "\033[2m"
NC = "" if _NO_COLOR else "\033[0m"

ICONS = {
    "PASS": f"{GREEN}✓{NC}",
    "WARN": f"{YELLOW}⚠{NC}",
    "FAIL": f"{RED}✗{NC}",
    "SKIP": f"{DIM}~{NC}",
}


@dataclass
class Check:
    name: str
    status: Status
    detail: str
    remedy: str = ""


@dataclass
class ValidationResult:
    target: Path
    checks: list[Check] = field(default_factory=list)

    @property
    def passes(self) -> int:
        return sum(1 for c in self.checks if c.status == "PASS")

    @property
    def warns(self) -> int:
        return sum(1 for c in self.checks if c.status == "WARN")

    @property
    def fails(self) -> int:
        return sum(1 for c in self.checks if c.status == "FAIL")

    def add(self, name: str, status: Status, detail: str, remedy: str = "") -> None:
        self.checks.append(Check(name, status, detail, remedy))


# ── Individual checks ─────────────────────────────────────────────────────────


def check_claude_dir(r: ValidationResult) -> None:
    d = r.target / ".claude"
    if d.is_dir():
        r.add(".claude/", "PASS", "Directory exists")
    else:
        r.add(".claude/", "FAIL", "Directory missing", "Re-run install.sh to create it")


def check_hooks(r: ValidationResult) -> None:
    hooks_dir = r.target / ".claude" / "hooks"
    if not hooks_dir.is_dir():
        r.add("Hooks dir", "FAIL", ".claude/hooks/ missing", "Re-run install.sh")
        return
    r.add("Hooks dir", "PASS", ".claude/hooks/ exists")

    required_hooks = [
        "block_dangerous.py",
        "secrets_scanner.py",
        "git_guardian.py",
    ]
    for hook in required_hooks:
        p = hooks_dir / hook
        if not p.exists():
            r.add(f"Hook: {hook}", "FAIL", "Missing", f"Re-run install.sh to restore {hook}")
        elif not os.access(p, os.X_OK):
            r.add(f"Hook: {hook}", "WARN", "Not executable", f"Run: chmod +x {p}")
        else:
            r.add(f"Hook: {hook}", "PASS", "Present and executable")

    optional_hooks = [
        "lint_on_edit.py",
        "context_monitor.py",
        "log_activity.py",
    ]
    for hook in optional_hooks:
        p = hooks_dir / hook
        if not p.exists():
            r.add(f"Hook: {hook}", "WARN", "Missing (optional)", "Re-run install.sh if needed")
        else:
            r.add(f"Hook: {hook}", "PASS", "Present")


def check_settings_json(r: ValidationResult) -> None:
    p = r.target / ".claude" / "settings.json"
    if not p.exists():
        r.add("settings.json", "FAIL", "Missing", "Re-run install.sh")
        return
    try:
        data = json.loads(p.read_text())
    except json.JSONDecodeError as e:
        r.add("settings.json", "FAIL", f"Invalid JSON: {e}", "Fix JSON syntax or re-install")
        return

    if "hooks" not in data:
        r.add("settings.json", "WARN", "Missing 'hooks' key", "Re-run install.sh to merge hooks")
    else:
        r.add("settings.json", "PASS", f"Valid JSON with {len(data['hooks'])} hook(s)")


def check_forge_config(r: ValidationResult) -> None:
    # May live in root or .claude/
    candidates = [
        r.target / "forge-config.json",
        r.target / ".claude" / "forge-config.json",
    ]
    cfg_path = next((p for p in candidates if p.exists()), None)

    if cfg_path is None:
        r.add("forge-config.json", "FAIL", "Missing", "Re-run install.sh to create it")
        return

    try:
        cfg = json.loads(cfg_path.read_text())
    except json.JSONDecodeError as e:
        r.add("forge-config.json", "FAIL", f"Invalid JSON: {e}", "Fix JSON or re-install")
        return

    location = cfg_path.relative_to(r.target)
    issues = []

    autonomy = cfg.get("autonomy", {})
    if "workflowExecution" not in autonomy:
        issues.append("missing autonomy.workflowExecution (older config schema)")
    if "autoMerge" not in autonomy:
        issues.append("missing autonomy.autoMerge")

    # Execution providers (optional section; absent = legacy claude behavior)
    execution = cfg.get("execution", {})
    if execution:
        name = execution.get("defaultProvider")
        providers = execution.get("providers", {})
        provider = providers.get(name) if name else None
        if provider is None:
            issues.append(
                f"execution.defaultProvider {name!r} has no matching entry in execution.providers"
            )
        else:
            ptype = str(provider.get("type", "")).lower()
            if ptype not in ("claude", "codex"):
                issues.append(f"execution provider type {ptype!r} is not supported (claude/codex)")
            elif ptype != "claude":
                # Informational: aux LLM subsystems still require the claude CLI
                r.add(
                    "execution.provider",
                    "WARN",
                    f"non-claude default provider {name!r}: executive loop, LLM planning, "
                    "semantic dedup/admission and team modes still use the claude CLI "
                    "and fall back to heuristics without it",
                    "See docs/configuration-reference.md — Execution Providers",
                )

    if issues:
        r.add("forge-config.json", "WARN", f"{location} — {'; '.join(issues)}", "Re-run install.sh --upgrade to refresh schema")
    else:
        r.add("forge-config.json", "PASS", f"Valid at {location}")


def check_forge_version(r: ValidationResult) -> None:
    p = r.target / ".forge-version"
    if p.exists():
        version = p.read_text().strip()
        r.add(".forge-version", "PASS", f"v{version}")
    else:
        r.add(".forge-version", "WARN", "Missing", "Re-run install.sh to stamp version")


def check_planning(r: ValidationResult) -> None:
    planning = r.target / ".planning"
    if not planning.is_dir():
        r.add(".planning/", "WARN", "Directory missing", "Re-run install.sh")
        return
    r.add(".planning/", "PASS", "Directory exists")

    for name in ("PROJECT.md", "ROADMAP.md", "STATE.md"):
        p = planning / name
        if p.exists():
            r.add(f".planning/{name}", "PASS", "Present")
        else:
            r.add(f".planning/{name}", "WARN", "Missing template", "Re-run install.sh")


def check_gitignore(r: ValidationResult) -> None:
    p = r.target / ".gitignore"
    if not p.exists():
        r.add(".gitignore", "WARN", "Missing", "Re-run install.sh to create it")
        return

    content = p.read_text()
    missing = []
    required = [
        ("logs/", "logs/"),
        (".company/state/", ".company/state/ or .company/state"),
        ("__pycache__/", "__pycache__/"),
        ("*.pyc", ".pyc"),
    ]
    for pattern, display in required:
        if pattern not in content and display not in content:
            missing.append(pattern)

    if missing:
        r.add(".gitignore", "WARN", f"Missing entries: {', '.join(missing)}", "Re-run install.sh --upgrade")
    else:
        r.add(".gitignore", "PASS", "Has required Forge + Python entries")


def check_bin_scripts(r: ValidationResult) -> None:
    bin_dir = r.target / "bin"
    if not bin_dir.is_dir():
        r.add("bin/", "WARN", "Directory missing", "Re-run install.sh")
        return
    r.add("bin/", "PASS", "Directory exists")

    required_bin = ["forge-queue", "forge-status", "forge-doctor"]
    for script in required_bin:
        p = bin_dir / script
        if not p.exists():
            r.add(f"bin/{script}", "WARN", "Missing", "Re-run install.sh")
        elif not os.access(p, os.X_OK):
            r.add(f"bin/{script}", "WARN", "Not executable", f"Run: chmod +x {p}")
        else:
            r.add(f"bin/{script}", "PASS", "Present and executable")


def check_company_extension(r: ValidationResult) -> None:
    company_dir = r.target / ".company"

    # Detect whether company extension should be present
    daemon_py = r.target / ".claude" / "hooks" / "company" / "forge_daemon.py"
    if not daemon_py.exists():
        r.add("Company extension", "SKIP", "Not installed (core-only mode)")
        return

    r.add("Company daemon", "PASS", "forge_daemon.py present")

    runtime_dirs = ["state", "logs", "employees"]
    for d in runtime_dirs:
        p = company_dir / d
        if p.is_dir():
            r.add(f".company/{d}/", "PASS", "Exists")
        else:
            r.add(f".company/{d}/", "WARN", "Missing runtime directory", f"mkdir -p {p}")


def check_no_org_data_leaked(r: ValidationResult) -> None:
    """Org data (org.json) should only exist if user explicitly ran /company-init."""
    org_json = r.target / ".company" / "org.json"
    if not org_json.exists():
        r.add("Org isolation", "SKIP", "No org.json (normal before /company-init)")
        return

    try:
        data = json.loads(org_json.read_text())
    except json.JSONDecodeError:
        r.add("Org isolation", "WARN", "org.json is invalid JSON", "Run /company-init to recreate")
        return

    # Check for foreign project paths that shouldn't be in this install
    target_str = str(r.target)
    foreign_paths = []
    for project in data.get("projects", []):
        path = project.get("path", "")
        if path and path != target_str and not path.startswith(target_str):
            foreign_paths.append(path)

    if foreign_paths:
        r.add(
            "Org isolation",
            "WARN",
            f"org.json references {len(foreign_paths)} non-local project path(s)",
            "Run /company-init to reset org data for this project",
        )
    else:
        r.add("Org isolation", "PASS", "org.json paths look local")


# ── Runner ────────────────────────────────────────────────────────────────────


def validate(target: Path) -> ValidationResult:
    r = ValidationResult(target=target)
    check_claude_dir(r)
    check_hooks(r)
    check_settings_json(r)
    check_forge_config(r)
    check_forge_version(r)
    check_planning(r)
    check_gitignore(r)
    check_bin_scripts(r)
    check_company_extension(r)
    check_no_org_data_leaked(r)
    return r


# ── Output ────────────────────────────────────────────────────────────────────


def print_human(r: ValidationResult, strict: bool) -> int:
    print(f"\n{BOLD}Forge Install Validation{NC}")
    print(f"{DIM}Target: {r.target}{NC}\n")

    for c in r.checks:
        icon = ICONS[c.status]
        remedy = f"\n    {DIM}→ {c.remedy}{NC}" if c.remedy and c.status in ("FAIL", "WARN") else ""
        print(f"  {icon}  {c.name:<28}  {c.detail}{remedy}")

    print()
    total = len(r.checks)
    print(f"  {BOLD}Results:{NC} {r.passes} passed, {r.warns} warning(s), {r.fails} failed  [{total} total]")
    print()

    fails = r.fails
    if strict:
        fails += r.warns

    if fails == 0:
        if r.warns > 0 and not strict:
            print(f"  {YELLOW}Installation COMPLETE with {r.warns} warning(s).{NC}")
        else:
            print(f"  {GREEN}Installation VALID.{NC}")
        print()
        return 0
    else:
        label = "failure(s)" if r.fails else "warning(s)"
        count = r.fails if r.fails else r.warns
        print(f"  {RED}Installation has {count} {label}.{NC}")
        print(f"  {DIM}Re-run: install.sh --upgrade {r.target}{NC}")
        print()
        return 1


def print_json(r: ValidationResult, strict: bool) -> int:
    fails = r.fails + (r.warns if strict else 0)
    output = {
        "target": str(r.target),
        "passed": r.passes,
        "warnings": r.warns,
        "failures": r.fails,
        "valid": fails == 0,
        "checks": [
            {"name": c.name, "status": c.status, "detail": c.detail, "remedy": c.remedy}
            for c in r.checks
        ],
    }
    print(json.dumps(output, indent=2))
    return 0 if fails == 0 else 1


# ── Entry point ───────────────────────────────────────────────────────────────


def main(argv: list[str] | None = None) -> int:
    args = argv if argv is not None else sys.argv[1:]

    target_dir: Path | None = None
    as_json = False
    strict = False

    i = 0
    while i < len(args):
        arg = args[i]
        if arg in ("--json", "-j"):
            as_json = True
        elif arg in ("--strict", "-s"):
            strict = True
        elif arg in ("--help", "-h"):
            print(__doc__)
            return 0
        elif not arg.startswith("-"):
            target_dir = Path(arg)
        else:
            print(f"Unknown flag: {arg}", file=sys.stderr)
            return 1
        i += 1

    target = (target_dir or Path.cwd()).resolve()
    if not target.is_dir():
        print(f"Error: target directory does not exist: {target}", file=sys.stderr)
        return 1

    result = validate(target)

    if as_json:
        return print_json(result, strict)
    else:
        return print_human(result, strict)


if __name__ == "__main__":
    sys.exit(main())
