#!/usr/bin/env bash
# forge-protect-main — Apply GitHub branch protection rules from forge-config.json
#
# Reads the branchProtection block from forge-config.json, builds the GitHub
# branch protection API payload, and applies it via gh api. Use --dry-run to
# preview the payload without making any changes.
#
# Usage:
#   forge-protect-main                    Apply protection to main branch
#   forge-protect-main --dry-run          Preview payload, no changes applied
#   forge-protect-main --branch develop   Apply to a specific branch
#   forge-protect-main --json             Machine-readable JSON output
#   forge-protect-main --help             Show this help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BACKEND="${SCRIPT_DIR}/.claude/hooks/company/protect_main.py"

if [ ! -f "$BACKEND" ]; then
    echo "Error: protect_main.py not found at ${BACKEND}" >&2
    exit 1
fi

case "${1:-}" in
    --help|-h)
        head -13 "$0" | tail -10
        exit 0
        ;;
    *)
        exec uv run "$BACKEND" "$@"
        ;;
esac
