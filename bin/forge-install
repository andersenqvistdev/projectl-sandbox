section "Git Configuration"

# Add Forge-specific ignores
_gi_updated=false
if [ -f ".gitignore" ]; then
    if ! grep -q ".company/state/" .gitignore 2>/dev/null; then
        echo -e "  $INFO Adding Forge entries to .gitignore..."
        cat >> .gitignore << 'GITIGNORE'

# Forge Framework
.company/state/
.company/results/
.company/logs/
.company/runtime/
.claude/worktrees/
GITIGNORE
        _gi_updated=true
    fi
    # Always add missing Python and coverage artifact excludes
    _gi_py=""
    grep -qF "__pycache__/" .gitignore 2>/dev/null || _gi_py="${_gi_py}__pycache__/\n"
    grep -q   "\.pyc"        .gitignore 2>/dev/null || _gi_py="${_gi_py}*.pyc\n"
    grep -q   "\.pyo"        .gitignore 2>/dev/null || _gi_py="${_gi_py}*.pyo\n"
    grep -q   "pytest_cache" .gitignore 2>/dev/null || _gi_py="${_gi_py}.pytest_cache/\n"
    grep -q   "ruff_cache"   .gitignore 2>/dev/null || _gi_py="${_gi_py}.ruff_cache/\n"
    grep -q   "\.coverage"   .gitignore 2>/dev/null || _gi_py="${_gi_py}.coverage*\n"
    grep -q   "htmlcov"      .gitignore 2>/dev/null || _gi_py="${_gi_py}htmlcov/\n"
    grep -q   "^dist/"       .gitignore 2>/dev/null || _gi_py="${_gi_py}dist/\n"
    grep -q   "egg-info"     .gitignore 2>/dev/null || _gi_py="${_gi_py}*.egg-info\n"
    if [ -n "$_gi_py" ]; then
        printf "\n# Python\n%b" "$_gi_py" >> .gitignore
        _gi_updated=true
    fi
    if [ "$_gi_updated" = "true" ]; then
        echo -e "  $CHECK Updated .gitignore"
    else
        echo -e "  $CHECK .gitignore already has Forge and Python entries"
    fi
else
    cat > .gitignore << 'GITIGNORE'
# Forge Framework
.company/state/
.company/results/
.company/logs/
.company/runtime/
.claude/worktrees/

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.coverage*
htmlcov/
dist/
*.egg-info
.venv/
venv/

# IDE
.idea/
.vscode/
*.swp
GITIGNORE
    echo -e "  $CHECK Created .gitignore"
fi

