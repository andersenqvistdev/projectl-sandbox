#!/usr/bin/env bash
# forge-roadmap — Forge Labs roadmap CLI
#
# Usage:
#   forge-roadmap validate     # Parse .planning/ROADMAP.md task tags; report problems
#   forge-roadmap status       # Show waves and their task states
#   forge-roadmap run          # Invoke the scheduler once
#   forge-roadmap help         # Show this help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SCHEDULER="${SCRIPT_DIR}/.claude/hooks/company/roadmap_scheduler.py"

if [ ! -f "$SCHEDULER" ]; then
    echo "Error: roadmap_scheduler.py not found at ${SCHEDULER}" >&2
    exit 1
fi

case "${1:-}" in
    validate|v)
        exec uv run "$SCHEDULER" validate
        ;;
    status|s)
        exec uv run "$SCHEDULER" status
        ;;
    run|r)
        exec uv run "$SCHEDULER" scan
        ;;
    help|--help|-h)
        head -8 "$0" | tail -5
        ;;
    "")
        head -8 "$0" | tail -5
        ;;
    *)
        echo "Error: unknown subcommand '${1}'" >&2
        echo "Run 'forge-roadmap help' for usage." >&2
        exit 1
        ;;
esac
