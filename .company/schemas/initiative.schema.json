{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "initiative.schema.json",
  "title": "Strategic Initiative Schema",
  "description": "Schema for strategic initiatives generated by the P15 strategic planner",
  "version": "1.1",
  "type": "object",
  "required": ["id", "title", "description", "goal_alignment", "size", "approval_required", "status", "owner"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique initiative identifier (e.g., P15-G5)",
      "pattern": "^[A-Z0-9-]+$"
    },
    "title": {
      "type": "string",
      "description": "Short title for the initiative",
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the initiative"
    },
    "goal_alignment": {
      "type": "array",
      "description": "Goal IDs this initiative supports",
      "items": {
        "type": "string",
        "pattern": "^G[0-9]+$"
      },
      "minItems": 1
    },
    "size": {
      "type": "string",
      "description": "Initiative size/effort classification",
      "enum": ["small", "medium", "large", "epic"]
    },
    "approval_required": {
      "type": "string",
      "description": "Approval level required",
      "enum": ["auto", "human", "executive"]
    },
    "status": {
      "type": "string",
      "description": "Current status of the initiative",
      "enum": ["proposed", "approved", "in_progress", "completed", "rejected", "blocked"]
    },
    "owner": {
      "type": "string",
      "description": "Employee ID responsible for this initiative"
    },
    "tasks": {
      "type": "array",
      "description": "Tasks that make up this initiative",
      "items": {
        "$ref": "#/definitions/task"
      }
    },
    "priority": {
      "type": "integer",
      "description": "Priority score (0-100, higher = more important)",
      "minimum": 0,
      "maximum": 100,
      "default": 50
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 timestamp when initiative was created",
      "format": "date-time"
    },
    "approved_at": {
      "type": ["string", "null"],
      "description": "ISO 8601 timestamp when initiative was approved",
      "format": "date-time"
    },
    "completed_at": {
      "type": ["string", "null"],
      "description": "ISO 8601 timestamp when initiative was completed",
      "format": "date-time"
    },
    "rejection_reason": {
      "type": ["string", "null"],
      "description": "Reason for rejection if status is rejected"
    },
    "parent_goal_id": {
      "type": ["string", "null"],
      "description": "Parent goal ID for hierarchy support",
      "pattern": "^G[0-9]+$"
    },
    "cycle_type": {
      "type": "string",
      "description": "Planning cycle type for this initiative",
      "enum": ["annual", "quarterly", "weekly", "daily"],
      "default": "weekly"
    },
    "velocity_metrics": {
      "type": "object",
      "description": "Velocity tracking metrics for the initiative",
      "properties": {
        "tasks_completed": {
          "type": "integer",
          "description": "Number of tasks completed",
          "minimum": 0,
          "default": 0
        },
        "tasks_failed": {
          "type": "integer",
          "description": "Number of tasks that failed",
          "minimum": 0,
          "default": 0
        },
        "days_active": {
          "type": "integer",
          "description": "Number of days the initiative has been active",
          "minimum": 0,
          "default": 0
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "task": {
      "type": "object",
      "required": ["id", "name", "description"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique task identifier within the initiative"
        },
        "name": {
          "type": "string",
          "description": "Short task name"
        },
        "description": {
          "type": "string",
          "description": "Detailed task description"
        },
        "file": {
          "type": ["string", "null"],
          "description": "File path this task operates on"
        },
        "action": {
          "type": "string",
          "description": "Type of action",
          "enum": ["implement", "create", "modify", "test", "verify", "fix", "analyze", "configure"],
          "default": "implement"
        },
        "acceptance": {
          "type": "string",
          "description": "Acceptance criteria for the task"
        },
        "estimated_effort": {
          "type": "string",
          "description": "Estimated effort level",
          "enum": ["small", "medium", "large"],
          "default": "small"
        },
        "status": {
          "type": "string",
          "description": "Current task status",
          "enum": ["pending", "queued", "in_progress", "completed", "failed"],
          "default": "pending"
        }
      }
    }
  }
}
